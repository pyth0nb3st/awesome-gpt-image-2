{
  "name": "awesome-gpt-image-2",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build:brand": "python3 scripts/build-brand-assets.py",
    "generate:readme": "node scripts/generate-readme.mjs",
    "validate:gallery": "node scripts/validate-gallery-policy.mjs",
    "prebuild": "npm run generate:readme && npm run validate:gallery && node scripts/generate-thumbnails.mjs",
    "dev": "next dev",
    "build": "next build && node scripts/copy-export-assets.mjs",
    "upload:r2-assets": "node scripts/upload-r2-assets.mjs",
    "deploy:cloudflare": "npm run build && npm run deploy:cloudflare:out",
    "deploy:cloudflare:out": "wrangler pages deploy out --project-name ${CLOUDFLARE_PAGES_PROJECT:-awesome-gpt-image-2}",
    "start": "next start"
  },
  "dependencies": {
    "next": "16.2.4",
    "react": "19.2.5",
    "react-dom": "19.2.5"
  }
}
